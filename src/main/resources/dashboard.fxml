<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane prefWidth="850.0" prefHeight="600.0" xmlns="http://javafx.com/javafx/8"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.vku.karaoke.client.controller.KaraokeDashboardController">

    <top>
        <HBox spacing="20.0" style="-fx-background-color: #2c3e50; -fx-padding: 15;">
            <children>
                <Label fx:id="lblWelcome" text="Xin chào: Khách" style="-fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold;"/>
                <Region HBox.hgrow="ALWAYS" />
                <Button text="Đăng Xuất" onAction="#handleLogout" style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-cursor: hand;"/>
            </children>
        </HBox>
    </top>

    <center>
        <VBox spacing="15.0" style="-fx-padding: 20;">
            <children>
                <HBox spacing="10.0" alignment="CENTER_LEFT">
                    <children>
                        <TextField fx:id="txtSearch" promptText="Nhập tên bài hát hoặc ca sĩ muốn tìm..." prefWidth="400.0"/>
                        <Button text="Tìm Kiếm Bài Hát" onAction="#handleSearch" style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-cursor: hand;"/>
                        <Button text="Tải Lại Tất Cả" onAction="#handleRefresh" style="-fx-background-color: #2ecc71; -fx-text-fill: white; -fx-cursor: hand;"/>
                    </children>
                </HBox>

                <TableView fx:id="tableSongs" prefHeight="250.0" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colId" text="Mã Bài Hát" prefWidth="120.0"/>
                        <TableColumn fx:id="colTitle" text="Tên Bài Hát Karaoke" prefWidth="250.0"/>
                        <TableColumn fx:id="colArtist" text="Ca Sĩ Thực Hiện" prefWidth="200.0"/>
                        <TableColumn fx:id="colGenre" text="Thể Loại Nhạc" prefWidth="150.0"/>
                    </columns>
                </TableView>

                <GridPane hgap="10" vgap="10" style="-fx-background-color: #edf2f7; -fx-padding: 15; -fx-background-radius: 5;">
                    <columnConstraints>
                        <ColumnConstraints minWidth="80" halignment="RIGHT"/>
                        <ColumnConstraints minWidth="150" halignment="LEFT"/>
                        <ColumnConstraints minWidth="80" halignment="RIGHT"/>
                        <ColumnConstraints minWidth="150" halignment="LEFT"/>
                    </columnConstraints>
                    <children>
                        <Label text="Mã Bài Hát:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                        <TextField fx:id="txtId" promptText="Ví dụ: BH004" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

                        <Label text="Tên Bài Hát:" GridPane.rowIndex="0" GridPane.columnIndex="2"/>
                        <TextField fx:id="txtTitle" promptText="Nhập tên bài..." GridPane.rowIndex="0" GridPane.columnIndex="3"/>

                        <Label text="Ca Sĩ:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                        <TextField fx:id="txtArtist" promptText="Nhập ca sĩ..." GridPane.rowIndex="1" GridPane.columnIndex="1"/>

                        <Label text="Thể Loại:" GridPane.rowIndex="1" GridPane.columnIndex="2"/>
                        <TextField fx:id="txtGenre" promptText="Nhập thể loại nhạc..." GridPane.rowIndex="1" GridPane.columnIndex="3"/>
                    </children>
                </GridPane>

                <HBox spacing="10.0" alignment="CENTER">
                    <children>
                        <Button fx:id="btnAdd" text="Thêm Mới (Admin)" onAction="#handleInsert" style="-fx-background-color: #2ecc71; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;"/>
                        <Button fx:id="btnUpdate" text="Sửa Thông Tin (Admin)" onAction="#handleUpdate" style="-fx-background-color: #f1c40f; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;"/>
                        <Button fx:id="btnDelete" text="Xóa Bài Hát (Admin)" onAction="#handleDelete" style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;"/>
                        <Separator orientation="VERTICAL" />
                        <Button text="Sao Lưu Txt (IOStream)" onAction="#handleExportTxt" style="-fx-background-color: #9b59b6; -fx-text-fill: white; -fx-cursor: hand;"/>
                        <Button text="Xuất File XML" onAction="#handleExportXml" style="-fx-background-color: #34495e; -fx-text-fill: white; -fx-cursor: hand;"/>
                    </children>
                </HBox>
            </children>
        </VBox>
    </center>
</BorderPane>